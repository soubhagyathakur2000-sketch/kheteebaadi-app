# ═════════════════════════════════════════════════════════════════════════════
# Kheteebaadi Production Environment Configuration
#
# Copy this file to .env and update values for your production environment:
#   cp .env.example.prod .env
#
# SECURITY WARNING: Never commit .env file to version control
# These variables contain sensitive credentials and must be kept secret
# ═════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────────────────────────────────────
APP_NAME=Kheteebaadi API
APP_VERSION=1.0.0
DEBUG=false

# ─────────────────────────────────────────────────────────────────────────────
# Database Configuration
# ─────────────────────────────────────────────────────────────────────────────
DB_USER=kheteebaadi_prod
DB_PASSWORD=change-me-to-a-strong-random-password-32-chars-min
DB_NAME=kheteebaadi_prod
DB_PORT=5432
# Complete DATABASE_URL for application
DATABASE_URL=postgresql+asyncpg://kheteebaadi_prod:change-me-to-a-strong-random-password-32-chars-min@db:5432/kheteebaadi_prod

# ─────────────────────────────────────────────────────────────────────────────
# Redis Configuration
# ─────────────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_PORT=6379
# Redis authentication (if enabled)
REDIS_PASSWORD=
# Redis memory configuration
REDIS_MAX_MEMORY=256mb
REDIS_EVICTION_POLICY=allkeys-lru

# ─────────────────────────────────────────────────────────────────────────────
# JWT & Authentication
# Generate a secure key with: openssl rand -hex 32
# ─────────────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# OTP Configuration
OTP_EXPIRE_SECONDS=300
OTP_LENGTH=6
OTP_MAX_ATTEMPTS_PER_HOUR=3

# ─────────────────────────────────────────────────────────────────────────────
# CORS Configuration
# Adjust origins to match your frontend deployment URLs
# ─────────────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["https://kheteebaadi.example.com","https://app.kheteebaadi.example.com"]

# ─────────────────────────────────────────────────────────────────────────────
# AWS S3 Configuration
# Required for file uploads and media storage
# ─────────────────────────────────────────────────────────────────────────────
AWS_REGION=ap-south-1
S3_BUCKET=kheteebaadi-prod
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

# ─────────────────────────────────────────────────────────────────────────────
# API Configuration
# ─────────────────────────────────────────────────────────────────────────────
API_PORT=8000
API_WORKERS=2

# ─────────────────────────────────────────────────────────────────────────────
# Rate Limiting
# ─────────────────────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=100

# ─────────────────────────────────────────────────────────────────────────────
# Sync Configuration
# ─────────────────────────────────────────────────────────────────────────────
SYNC_BATCH_MAX_SIZE=50
SYNC_IDEMPOTENCY_TTL_HOURS=72

# ─────────────────────────────────────────────────────────────────────────────
# Cache TTL Configuration (in seconds)
# ─────────────────────────────────────────────────────────────────────────────
CACHE_TTL_MANDI_PRICES=900
CACHE_TTL_VILLAGES=3600
CACHE_TTL_MANDIS=3600

# ─────────────────────────────────────────────────────────────────────────────
# Celery Configuration
# ─────────────────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_CONCURRENCY=2
CELERY_LOG_LEVEL=info

# ═════════════════════════════════════════════════════════════════════════════
# PRODUCTION SECURITY CHECKLIST
# ═════════════════════════════════════════════════════════════════════════════
# Before deploying to production, ensure:
#
# 1. JWT_SECRET_KEY - Generated with: openssl rand -hex 32
# 2. DB_PASSWORD - Strong password (32+ characters, mixed case, symbols)
# 3. DEBUG=false - Never enable debug in production
# 4. CORS_ORIGINS - Updated to your actual frontend domain(s)
# 5. AWS credentials - Use IAM roles instead if possible
# 6. All URLs use HTTPS - Update protocol if needed
# 7. Database - Use managed database service (RDS, Cloud SQL, etc)
# 8. Redis - Enable AUTH, use managed service if available
# 9. Secrets - Use secrets manager (AWS Secrets Manager, HashiCorp Vault)
# 10. Monitoring - Set up logging and alerting
#
# ═════════════════════════════════════════════════════════════════════════════
